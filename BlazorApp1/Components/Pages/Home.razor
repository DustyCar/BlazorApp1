@page "/"
@rendermode InteractiveServer
@using BlazorApp1.Services
@using Microsoft.AspNetCore.Authorization
@inject IJSRuntime JS
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms
@attribute [Authorize]

<PageTitle>Home</PageTitle>

<div style="display: flex; flex-direction: column;">
    <textarea style="height: 25vh" @bind="inputText" @bind:event="oninput"></textarea>
    <label for="method">Choose encryption:</label>
    <select id="method" name="method" @bind="selectedMethod">
        <option value="caesar">Caesar Cipher</option>
        <option value="vigenere">Vigenere Cipher</option>
    </select>
    <label>Load normal file:</label>
    <InputFile OnChange='@(e => LoadFile( e, false ))' />
    <button type="button" @onclick="EncryptText">Encrypt</button>
    <textarea readonly style="height: 25vh" @bind="outputText"></textarea>
    <button type="button" @onclick="DecryptText">Decrypt</button>
</div>

<div>
    <input @bind="fileName" placeholder="Enter file name" />
    <button type="button" @onclick="SaveFile">SAVE</button>
    <label>Load encrypted file:</label>
    <InputFile OnChange='@(e => LoadFile( e, true ))' />
    <button type="button" @onclick="ClearText">CLEAR</button>
</div>



@code {
    private string inputText = "";
    private string outputText = "";
    private string fileName = "encrypted.txt";
    private string selectedMethod = "caesar";
    private encryptionService service = new encryptionService();

    private void EncryptText()
    {
        if( selectedMethod == "caesar" )
        {
            outputText = service.Encrypt( inputText );
        }
        else if( selectedMethod == "vigenere" )
        {
            outputText = service.VigenèreEncrypt( inputText );
        }

        inputText = "";
    }

    private void DecryptText()
    {
        if( selectedMethod == "caesar" )
        {
            inputText = service.Decrypt( outputText );
        }
        else if( selectedMethod == "vigenere" )
        {
            inputText = service.VigenèreDecrypt( outputText );
        }

        outputText = "";
    }

    private async Task SaveFile()
    {
        await JS.InvokeVoidAsync( "downloadFile", fileName, outputText );
    }

    private async Task LoadFile( InputFileChangeEventArgs e, bool encrypted )
    {
        var file = e.File;

        using var stream = file.OpenReadStream();
        using var reader = new StreamReader( stream );

        string text = await reader.ReadToEndAsync();

        if( encrypted )
        {
            outputText = text;
        }
        else
        {
            inputText = text;
        }
    }

    private void ClearText()
    {
        inputText = "";
        outputText = "";
	}

}